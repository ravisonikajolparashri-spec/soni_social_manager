# ── Copy this to .env and fill in values ────────────────────────────────────

# Database (Railway auto-injects this — or use your own Postgres URL)
# Accepts both postgresql:// and postgresql+asyncpg:// formats
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smmpanel

# JWT — generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# BluesSMM Panel API
SMM_API_URL=https://bluesmmpanel.com/api/v2
SMM_API_KEY=your_bluesmmpanel_api_key_here

# App settings
APP_NAME=SMM Panel
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=changeme123

# CORS — comma-separated list of allowed frontend origins
# Add your Vercel URL here once deployed, e.g.:
# ALLOWED_ORIGINS=https://soni-social-manager.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Set to false in production to hide /docs and /redoc
SHOW_DOCS=true
